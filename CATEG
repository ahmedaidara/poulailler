<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Gestion des Stocks - DAKAR CHICKEN EXPRESS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        header {
            background: linear-gradient(135deg, #1e3c2c 0%, #2a5a3a 100%);
            color: white;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        header h1 {
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .production-selector {
            background: rgba(255,255,255,0.2);
            padding: 8px 15px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .production-selector label {
            font-size: 0.85rem;
        }

        .production-selector select {
            padding: 8px 15px;
            border-radius: 20px;
            border: none;
            font-weight: bold;
            background: white;
            cursor: pointer;
        }

        .main-content {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
        }

        .stock-section {
            flex: 1.2;
            padding: 25px;
            background: #f8fafc;
            border-right: 1px solid #e2e8f0;
        }

        .invoice-section {
            flex: 1;
            padding: 25px;
            background: white;
        }

        .section-title {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e2e8f0;
        }

        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .category-card {
            background: white;
            border-radius: 16px;
            padding: 15px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        }

        .category-card:hover {
            border-color: #2a5a3a;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        }

        .category-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid #f0f0f0;
        }

        .category-name {
            font-weight: bold;
            color: #1e293b;
            font-size: 0.95rem;
        }

        .category-price {
            background: #2a5a3a;
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .category-weight {
            font-size: 0.7rem;
            color: #64748b;
            margin-bottom: 12px;
        }

        .category-stock {
            background: #f0fdf4;
            padding: 8px;
            border-radius: 10px;
            margin-bottom: 12px;
            text-align: center;
        }

        .category-stock span {
            font-weight: bold;
            color: #10b981;
            font-size: 1.1rem;
        }

        .category-input-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .category-input {
            flex: 1;
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 1rem;
            text-align: center;
            font-weight: bold;
        }

        .category-input:focus {
            border-color: #2a5a3a;
            outline: none;
        }

        .btn-update-cat {
            background: #f59e0b;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.75rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .btn-update-cat:hover {
            background: #d97706;
        }

        .stock-actions {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: flex-end;
        }

        .btn-save-all {
            background: #10b981;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-save-all:hover {
            background: #059669;
        }

        .client-info {
            background: #f8fafc;
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 20px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .input-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #334155;
        }

        .input-group input {
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 0.9rem;
        }

        .input-group input:focus {
            border-color: #2a5a3a;
            outline: none;
        }

        .summary {
            background: #f8fafc;
            padding: 20px;
            border-radius: 16px;
            margin: 20px 0;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            padding: 15px 0 0 0;
            font-size: 1.2rem;
            font-weight: bold;
            color: #1e293b;
            border-top: 2px solid #e2e8f0;
            margin-top: 10px;
        }

        .paiement-section {
            background: #f8fafc;
            padding: 20px;
            border-radius: 16px;
            margin: 20px 0;
        }

        .mode-paiement {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .mode-paiement label {
            display: flex;
            align-items: center;
            gap: 8px;
            background: white;
            padding: 8px 15px;
            border-radius: 30px;
            border: 1px solid #e2e8f0;
            cursor: pointer;
        }

        .montant-input input {
            width: 100%;
            padding: 12px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 1rem;
        }

        .paiement-resume {
            background: white;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 15px;
        }

        .paiement-resume div {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
        }

        .actions {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
        }

        .btn-primary {
            background: #2a5a3a;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #1e3c2c;
        }

        .btn-secondary {
            background: #e2e8f0;
            color: #334155;
            border: none;
            padding: 12px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-modify {
            background: #3b82f6;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.75rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .btn-modify:hover {
            background: #2563eb;
        }

        .btn-delete {
            background: #ef4444;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.75rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .btn-delete:hover {
            background: #dc2626;
        }

        .add-production-btn {
            background: #10b981;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: bold;
            font-size: 0.8rem;
        }

        .add-production-btn:hover {
            background: #059669;
        }

        .production-actions {
            display: flex;
            gap: 5px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .modal-content h3 {
            margin-bottom: 20px;
            color: #1e293b;
        }

        .modal-content input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .message {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 12px 20px;
            border-radius: 10px;
            color: white;
            font-weight: bold;
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }

        .message.success { background: #10b981; }
        .message.error { background: #ef4444; }
        .message.warning { background: #f59e0b; }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @keyframes slideOut {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }

        @media (max-width: 900px) {
            .main-content { flex-direction: column; }
            .stock-section { border-right: none; border-bottom: 1px solid #e2e8f0; }
        }
    </style>
</head>
<body>

<div class="app-container">
    <header>
        <h1><i class="fas fa-chicken"></i> DAKAR CHICKEN EXPRESS</h1>
        <div class="production-selector">
            <label><i class="fas fa-calendar-alt"></i> Production :</label>
            <select id="productionSelect">
                <option value="">-- Chargement --</option>
            </select>
            <button id="addProductionBtn" class="add-production-btn">
                <i class="fas fa-plus"></i> Nouvelle
            </button>
            <div id="productionActions" class="production-actions"></div>
        </div>
    </header>

    <div class="main-content">
        <div class="stock-section">
            <div class="section-title">
                <i class="fas fa-boxes"></i> Gestion des Stocks par Catégorie
            </div>
            <div id="categoriesContainer" class="categories-grid">
                <div style="text-align: center; padding: 40px;">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Chargement...</p>
                </div>
            </div>
            <div class="stock-actions">
                <button id="saveAllBtn" class="btn-save-all">
                    <i class="fas fa-save"></i> Enregistrer toutes les modifications
                </button>
            </div>
        </div>

        <div class="invoice-section">
            <div class="section-title">
                <i class="fas fa-file-invoice"></i> Nouvelle Facture
            </div>

            <div class="client-info">
                <h3 style="margin-bottom: 15px;"><i class="fas fa-user-circle"></i> Informations Client</h3>
                <div class="info-grid">
                    <div class="input-group">
                        <label>Nom et Prénom</label>
                        <input type="text" id="clientName" placeholder="Ex: Moussa Diallo">
                    </div>
                    <div class="input-group">
                        <label>Téléphone</label>
                        <input type="tel" id="clientPhone" placeholder="Ex: 77 777 77 77">
                    </div>
                    <div class="input-group">
                        <label>Adresse</label>
                        <input type="text" id="clientAddress" placeholder="Ex: Dakar, Yoff">
                    </div>
                </div>
            </div>

            <h3 style="margin-bottom: 15px;"><i class="fas fa-shopping-cart"></i> Sélection des Poulets</h3>
            <div id="invoiceCategoriesContainer" class="categories-grid">
                <div style="text-align: center; padding: 40px;">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Chargement...</p>
                </div>
            </div>

            <div class="summary">
                <h3 style="margin-bottom: 15px;"><i class="fas fa-calculator"></i> Récapitulatif</h3>
                <div id="selectedItemsList">
                    <div style="text-align: center; color: #999; padding: 20px;">
                        <i class="fas fa-shopping-cart"></i>
                        <p>Aucun poulet sélectionné</p>
                    </div>
                </div>
                <div class="summary-total">
                    <span>TOTAL TTC</span>
                    <span id="totalAmount" style="color: #2a5a3a;">0 F CFA</span>
                </div>
            </div>

            <div class="paiement-section">
                <h3 style="margin-bottom: 15px;"><i class="fas fa-money-bill-wave"></i> Paiement</h3>
                <div class="mode-paiement">
                    <label><input type="radio" name="modePaiement" value="especes" checked> 💵 Espèces</label>
                    <label><input type="radio" name="modePaiement" value="wave"> 📱 Wave</label>
                    <label><input type="radio" name="modePaiement" value="orange"> 📱 Orange Money</label>
                </div>
                <div class="montant-input">
                    <label>Montant reçu (F CFA)</label>
                    <input type="number" id="montantPaye" value="0" min="0" step="100">
                </div>
                <div class="paiement-resume">
                    <div><span>Total facture :</span> <strong id="resumeTotal">0 F CFA</strong></div>
                    <div><span>Payé :</span> <strong id="resumePaye">0 F CFA</strong></div>
                    <div><span>Reste :</span> <strong id="resumeReste">0 F CFA</strong></div>
                </div>
                <div id="statutPaiement" style="text-align: center; padding: 8px; border-radius: 8px; display: none;"></div>
            </div>

            <div class="actions">
                <button id="generatePdfBtn" class="btn-secondary">
                    <i class="fas fa-file-pdf"></i> Générer PDF
                </button>
                <button id="saveInvoiceBtn" class="btn-primary">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODALS -->
<div id="newProductionModal" class="modal">
    <div class="modal-content">
        <h3><i class="fas fa-plus"></i> Nouvelle production</h3>
        <div class="input-group">
            <label>Nom de la production</label>
            <input type="text" id="newProductionName" placeholder="Ex: PROD 1">
        </div>
        <div class="input-group">
            <label>Date de début *</label>
            <input type="date" id="newStartDate">
        </div>
        <div class="input-group">
            <label>Date de fin</label>
            <input type="date" id="newEndDate">
        </div>
        <div class="input-group">
            <label>Stock initial (total poulets)</label>
            <input type="number" id="newInitialStock" placeholder="0">
        </div>
        <div class="modal-buttons">
            <button id="cancelNewBtn" class="btn-secondary">Annuler</button>
            <button id="confirmNewBtn" class="btn-primary">Créer</button>
        </div>
    </div>
</div>

<div id="modifyModal" class="modal">
    <div class="modal-content">
        <h3><i class="fas fa-edit"></i> Modifier la production</h3>
        <div class="input-group">
            <label>Nom de la production</label>
            <input type="text" id="modifyProductionName">
        </div>
        <div class="input-group">
            <label>Date de début</label>
            <input type="date" id="modifyStartDate">
        </div>
        <div class="input-group">
            <label>Date de fin</label>
            <input type="date" id="modifyEndDate">
        </div>
        <div class="input-group">
            <label>Stock initial</label>
            <input type="number" id="modifyInitialStock">
        </div>
        <div class="modal-buttons">
            <button id="cancelModifyBtn" class="btn-secondary">Annuler</button>
            <button id="confirmModifyBtn" class="btn-primary">Modifier</button>
        </div>
    </div>
</div>

<div id="deleteModal" class="modal">
    <div class="modal-content">
        <h3><i class="fas fa-trash"></i> Confirmer la suppression</h3>
        <p>Tapez <strong>"SUPPRIMER"</strong> pour confirmer :</p>
        <input type="text" id="deleteConfirmInput" placeholder="Tapez SUPPRIMER ici">
        <div class="modal-buttons">
            <button id="cancelDeleteBtn" class="btn-secondary">Annuler</button>
            <button id="confirmDeleteBtn" class="btn-delete">Supprimer</button>
        </div>
    </div>
</div>

<script>
    // Configuration Firebase
    const firebaseConfig = {
        apiKey: "AIzaSyAAQ9G3w94aM7iGc_ufHMzdCvrwzzEzlhI",
        authDomain: "poulailler-3515e.firebaseapp.com",
        projectId: "poulailler-3515e",
        storageBucket: "poulailler-3515e.firebasestorage.app",
        messagingSenderId: "482441929117",
        appId: "1:482441929117:web:7970df401b0125560acf74"
    };

    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();

    // Catégories
    const categories = [
        { id: '1', name: "Très petits", weight: "1.0-1.1 kg", defaultPrice: 2000, fieldQty: 'small1Quantity', fieldSold: 'small1Sold', fieldPrice: 'small1Price' },
        { id: '2', name: "Petits", weight: "1.2 kg", defaultPrice: 2500, fieldQty: 'small2Quantity', fieldSold: 'small2Sold', fieldPrice: 'small2Price' },
        { id: '3', name: "Moyens-petits", weight: "1.3-1.4 kg", defaultPrice: 3000, fieldQty: 'medium1Quantity', fieldSold: 'medium1Sold', fieldPrice: 'medium1Price' },
        { id: '4', name: "Moyens", weight: "1.5-1.6 kg", defaultPrice: 3300, fieldQty: 'medium2Quantity', fieldSold: 'medium2Sold', fieldPrice: 'medium2Price' },
        { id: '5', name: "Moyens-grands", weight: "1.7-1.9 kg", defaultPrice: 3500, fieldQty: 'large1Quantity', fieldSold: 'large1Sold', fieldPrice: 'large1Price' },
        { id: '6', name: "Grands", weight: "2.0 kg", defaultPrice: 3700, fieldQty: 'large2Quantity', fieldSold: 'large2Sold', fieldPrice: 'large2Price' },
        { id: '7', name: "Très grands", weight: "2.1-2.3 kg", defaultPrice: 4000, fieldQty: 'xlarge1Quantity', fieldSold: 'xlarge1Sold', fieldPrice: 'xlarge1Price' },
        { id: '8', name: "Géants", weight: "+2.4 kg", defaultPrice: 4500, fieldQty: 'xlarge2Quantity', fieldSold: 'xlarge2Sold', fieldPrice: 'xlarge2Price' }
    ];

    let allProductions = [];
    let currentProduction = null;
    let currentBoutique = { id: 'sacre-coeur-3', name: 'SACRÉ COEUR 3', phone: '77 777 77 81' };
    let selectedItems = {};

    // Fonction message
    function showMessage(text, type) {
        const msg = document.createElement('div');
        msg.className = `message ${type}`;
        msg.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i> ${text}`;
        document.body.appendChild(msg);
        setTimeout(() => {
            msg.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => msg.remove(), 300);
        }, 3000);
    }

    // Charger productions
    async function loadProductions() {
        try {
            const snapshot = await db.collection('poulailler_records').orderBy('startDate', 'desc').get();
            allProductions = [];
            snapshot.forEach(doc => allProductions.push({ id: doc.id, ...doc.data() }));
            
            const select = document.getElementById('productionSelect');
            if (!select) return;
            
            select.innerHTML = '<option value="">-- Sélectionner --</option>';
            allProductions.forEach(prod => {
                const date = prod.startDate ? new Date(prod.startDate).toLocaleDateString('fr-FR') : 'Date inconnue';
                const option = document.createElement('option');
                option.value = prod.id;
                option.textContent = `${prod.productionName || 'Production'} - ${date}`;
                select.appendChild(option);
            });
            
            // Ajouter boutons modif/suppr
            const actionsDiv = document.getElementById('productionActions');
            if (actionsDiv && allProductions.length > 0) {
                actionsDiv.innerHTML = `
                    <button id="modifyCurrentBtn" class="btn-modify"><i class="fas fa-edit"></i> Modifier</button>
                    <button id="deleteCurrentBtn" class="btn-delete"><i class="fas fa-trash"></i> Supprimer</button>
                `;
                document.getElementById('modifyCurrentBtn')?.addEventListener('click', () => {
                    const id = select.value;
                    if (id) modifyProduction(id);
                });
                document.getElementById('deleteCurrentBtn')?.addEventListener('click', () => {
                    const id = select.value;
                    if (id) deleteProduction(id);
                });
            }
            
            if (allProductions.length > 0) {
                select.value = allProductions[0].id;
                await loadProduction(allProductions[0].id);
            }
            
            select.addEventListener('change', async () => {
                if (select.value) await loadProduction(select.value);
            });
            
        } catch (error) {
            console.error(error);
            showMessage('Erreur chargement', 'error');
        }
    }

    // Charger une production
    async function loadProduction(id) {
        try {
            const doc = await db.collection('poulailler_records').doc(id).get();
            if (doc.exists) {
                currentProduction = { id: doc.id, ...doc.data() };
                displayCategories();
                displayInvoiceCategories();
            }
        } catch (error) {
            console.error(error);
            showMessage('Erreur chargement production', 'error');
        }
    }

    // Afficher catégories stock
    function displayCategories() {
        const container = document.getElementById('categoriesContainer');
        if (!container || !currentProduction) return;
        container.innerHTML = '';
        
        categories.forEach(cat => {
            const qty = currentProduction[cat.fieldQty] || 0;
            const price = currentProduction[cat.fieldPrice] || cat.defaultPrice;
            const sold = currentProduction[cat.fieldSold] || 0;
            const restant = Math.max(0, qty - sold);
            
            const card = document.createElement('div');
            card.className = 'category-card';
            card.innerHTML = `
                <div class="category-header">
                    <span class="category-name">${cat.name}</span>
                    <span class="category-price" id="price_display_${cat.id}">${price.toLocaleString()} F CFA</span>
                </div>
                <div class="category-weight">${cat.weight}</div>
                <div class="category-stock">
                    📦 Stock: <span id="stock_display_${cat.id}">${qty}</span> | 
                    Vendu: ${sold} | 
                    Restant: <span style="color:${restant>0?'#10b981':'#ef4444'}">${restant}</span>
                </div>
                <div class="category-input-group">
                    <input type="number" id="qty_${cat.id}" class="category-input" value="${qty}" min="0" placeholder="Qté">
                    <input type="number" id="price_${cat.id}" class="category-input" value="${price}" min="0" step="100" placeholder="Prix" style="width:100px">
                    <button class="btn-update-cat" onclick="updateCategory('${cat.id}')"><i class="fas fa-save"></i></button>
                </div>
            `;
            container.appendChild(card);
        });
    }

    // Mettre à jour catégorie
    window.updateCategory = async function(catId) {
        if (!currentProduction) return;
        const cat = categories.find(c => c.id === catId);
        if (!cat) return;
        
        const newQty = parseInt(document.getElementById(`qty_${catId}`).value) || 0;
        const newPrice = parseInt(document.getElementById(`price_${catId}`).value) || 0;
        
        try {
            const update = {};
            update[cat.fieldQty] = newQty;
            update[cat.fieldPrice] = newPrice;
            await db.collection('poulailler_records').doc(currentProduction.id).update(update);
            currentProduction[cat.fieldQty] = newQty;
            currentProduction[cat.fieldPrice] = newPrice;
            displayCategories();
            displayInvoiceCategories();
            showMessage(`${cat.name} mis à jour`, 'success');
        } catch(error) {
            showMessage('Erreur', 'error');
        }
    };

    // Afficher catégories facture
    function displayInvoiceCategories() {
        const container = document.getElementById('invoiceCategoriesContainer');
        if (!container || !currentProduction) return;
        container.innerHTML = '';
        
        categories.forEach(cat => {
            const total = currentProduction[cat.fieldQty] || 0;
            const sold = currentProduction[cat.fieldSold] || 0;
            const restant = Math.max(0, total - sold);
            const price = currentProduction[cat.fieldPrice] || cat.defaultPrice;
            
            const card = document.createElement('div');
            card.className = 'category-card';
            card.innerHTML = `
                <div style="display:flex; justify-content:space-between;">
                    <strong>${cat.name}</strong>
                    <span style="background:#2a5a3a; color:white; padding:5px 15px; border-radius:20px;">${price.toLocaleString()} F CFA</span>
                </div>
                <div style="color:#666; margin:10px 0;">${cat.weight}</div>
                <div style="background:#f0fdf4; padding:10px; border-radius:10px; text-align:center; margin-bottom:10px;">
                    <strong>Stock restant: ${restant}</strong>
                </div>
                <input type="number" id="invoice_qty_${cat.id}" class="category-input" 
                    data-id="${cat.id}" data-name="${cat.name}" data-weight="${cat.weight}" 
                    data-price="${price}" max="${restant}" min="0" value="0" 
                    placeholder="Quantité" ${restant === 0 ? 'disabled' : ''}>
            `;
            container.appendChild(card);
        });
        
        document.querySelectorAll('#invoiceCategoriesContainer .category-input').forEach(input => {
            input.addEventListener('input', updateSummary);
        });
        selectedItems = {};
        updateSummary();
    }

    // Mettre à jour résumé
    function updateSummary() {
        selectedItems = {};
        let total = 0;
        
        categories.forEach(cat => {
            const input = document.getElementById(`invoice_qty_${cat.id}`);
            if (input) {
                let qty = parseInt(input.value) || 0;
                const max = parseInt(input.max) || 0;
                if (qty > max) { qty = max; input.value = max; }
                const price = parseInt(input.dataset.price) || 0;
                if (qty > 0) {
                    selectedItems[cat.id] = {
                        id: cat.id, name: cat.name, weight: cat.weight,
                        price: price, quantity: qty, subtotal: qty * price
                    };
                    total += qty * price;
                }
            }
        });
        
        document.getElementById('totalAmount').innerHTML = total.toLocaleString() + ' F CFA';
        
        const container = document.getElementById('selectedItemsList');
        if (Object.keys(selectedItems).length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:20px;"><i class="fas fa-shopping-cart"></i><p>Aucun poulet sélectionné</p></div>';
        } else {
            let html = '';
            Object.values(selectedItems).forEach(item => {
                html += `<div class="summary-item"><div><strong>${item.name}</strong><br><small>${item.weight}</small></div><div>${item.quantity} × ${item.price.toLocaleString()} F CFA<br><strong>${item.subtotal.toLocaleString()} F CFA</strong></div></div>`;
            });
            container.innerHTML = html;
        }
        
        updatePaiementResume();
    }

    function updatePaiementResume() {
        const total = parseInt(document.getElementById('totalAmount').innerHTML.replace(/\D/g,'')) || 0;
        const paye = parseInt(document.getElementById('montantPaye').value) || 0;
        const reste = Math.max(0, total - paye);
        document.getElementById('resumeTotal').innerHTML = total.toLocaleString() + ' F CFA';
        document.getElementById('resumePaye').innerHTML = paye.toLocaleString() + ' F CFA';
        document.getElementById('resumeReste').innerHTML = reste.toLocaleString() + ' F CFA';
    }

    // Enregistrer facture
    document.getElementById('saveInvoiceBtn')?.addEventListener('click', async () => {
        if (Object.keys(selectedItems).length === 0) {
            showMessage('Sélectionnez des articles', 'error');
            return;
        }
        
        for (const [id, item] of Object.entries(selectedItems)) {
            const cat = categories.find(c => c.id === id);
            if (cat) {
                const total = currentProduction[cat.fieldQty] || 0;
                const sold = currentProduction[cat.fieldSold] || 0;
                if (item.quantity > (total - sold)) {
                    showMessage(`Stock insuffisant pour ${cat.name}`, 'error');
                    return;
                }
            }
        }
        
        const total = parseInt(document.getElementById('totalAmount').innerHTML.replace(/\D/g,'')) || 0;
        const paye = parseInt(document.getElementById('montantPaye').value) || 0;
        const mode = document.querySelector('input[name="modePaiement"]:checked')?.value || 'especes';
        const reste = total - paye;
        const statut = paye === 0 ? 'impaye' : (paye >= total ? 'paye' : 'partiel');
        const invoiceNumber = `FACT-${Date.now()}`;
        
        const invoiceData = {
            boutique: currentBoutique.id,
            boutiqueName: currentBoutique.name,
            productionId: currentProduction.id,
            productionName: currentProduction.productionName,
            client: {
                name: document.getElementById('clientName').value || 'Client',
                phone: document.getElementById('clientPhone').value || 'Non renseigné',
                address: document.getElementById('clientAddress').value || ''
            },
            items: Object.values(selectedItems),
            total: total,
            paiement: { montantPaye: paye, resteAPayer: reste, modePaiement: mode, statut: statut },
            invoiceNumber: invoiceNumber,
            date: new Date().toISOString()
        };
        
        try {
            const update = {};
            for (const [id, item] of Object.entries(selectedItems)) {
                const cat = categories.find(c => c.id === id);
                if (cat) update[cat.fieldSold] = (currentProduction[cat.fieldSold] || 0) + item.quantity;
            }
            await db.collection('poulailler_records').doc(currentProduction.id).update(update);
            await db.collection('invoices').add(invoiceData);
            
            showMessage('Facture enregistrée', 'success');
            await loadProduction(currentProduction.id);
            
            document.getElementById('clientName').value = '';
            document.getElementById('clientPhone').value = '';
            document.getElementById('clientAddress').value = '';
            document.getElementById('montantPaye').value = '0';
            
        } catch(error) {
            showMessage('Erreur: ' + error.message, 'error');
        }
    });

    document.getElementById('generatePdfBtn')?.addEventListener('click', () => {
        if (Object.keys(selectedItems).length === 0) {
            showMessage('Aucun article', 'error');
            return;
        }
        showMessage('PDF généré', 'success');
    });

    document.getElementById('saveAllBtn')?.addEventListener('click', async () => {
        if (!currentProduction) return;
        const update = {};
        for (const cat of categories) {
            const qty = parseInt(document.getElementById(`qty_${cat.id}`)?.value) || 0;
            const price = parseInt(document.getElementById(`price_${cat.id}`)?.value) || 0;
            update[cat.fieldQty] = qty;
            update[cat.fieldPrice] = price;
        }
        try {
            await db.collection('poulailler_records').doc(currentProduction.id).update(update);
            await loadProduction(currentProduction.id);
            showMessage('Stocks mis à jour', 'success');
        } catch(error) {
            showMessage('Erreur', 'error');
        }
    });

    document.getElementById('montantPaye')?.addEventListener('input', updatePaiementResume);

    // Gestion des modals
    document.getElementById('addProductionBtn')?.addEventListener('click', () => {
        document.getElementById('newProductionModal').style.display = 'flex';
    });
    
    document.getElementById('cancelNewBtn')?.addEventListener('click', () => {
        document.getElementById('newProductionModal').style.display = 'none';
    });
    
    document.getElementById('confirmNewBtn')?.addEventListener('click', async () => {
        const name = document.getElementById('newProductionName').value.trim();
        const start = document.getElementById('newStartDate').value;
        if (!name || !start) {
            showMessage('Nom et date début requis', 'error');
            return;
        }
        
        const newProd = {
            productionName: name,
            startDate: new Date(start),
            endDate: document.getElementById('newEndDate').value ? new Date(document.getElementById('newEndDate').value) : null,
            initialStock: parseInt(document.getElementById('newInitialStock').value) || 0,
            small1Quantity: 0, small1Sold: 0, small1Price: 2000,
            small2Quantity: 0, small2Sold: 0, small2Price: 2500,
            medium1Quantity: 0, medium1Sold: 0, medium1Price: 3000,
            medium2Quantity: 0, medium2Sold: 0, medium2Price: 3300,
            large1Quantity: 0, large1Sold: 0, large1Price: 3500,
            large2Quantity: 0, large2Sold: 0, large2Price: 3700,
            xlarge1Quantity: 0, xlarge1Sold: 0, xlarge1Price: 4000,
            xlarge2Quantity: 0, xlarge2Sold: 0, xlarge2Price: 4500,
            createdAt: new Date().toISOString()
        };
        
        try {
            await db.collection('poulailler_records').add(newProd);
            document.getElementById('newProductionModal').style.display = 'none';
            await loadProductions();
            showMessage('Production créée', 'success');
        } catch(error) {
            showMessage('Erreur création', 'error');
        }
    });
    
    document.getElementById('cancelModifyBtn')?.addEventListener('click', () => {
        document.getElementById('modifyModal').style.display = 'none';
    });
    
    document.getElementById('confirmModifyBtn')?.addEventListener('click', async () => {
        if (!window._modifyId) return;
        const name = document.getElementById('modifyProductionName').value.trim();
        const start = document.getElementById('modifyStartDate').value;
        if (!name || !start) {
            showMessage('Nom et date requis', 'error');
            return;
        }
        try {
            await db.collection('poulailler_records').doc(window._modifyId).update({
                productionName: name,
                startDate: new Date(start),
                endDate: document.getElementById('modifyEndDate').value ? new Date(document.getElementById('modifyEndDate').value) : null,
                initialStock: parseInt(document.getElementById('modifyInitialStock').value) || 0
            });
            document.getElementById('modifyModal').style.display = 'none';
            await loadProductions();
            showMessage('Production modifiée', 'success');
        } catch(error) {
            showMessage('Erreur', 'error');
        }
    });
    
    document.getElementById('cancelDeleteBtn')?.addEventListener('click', () => {
        document.getElementById('deleteModal').style.display = 'none';
    });
    
    document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
        const confirm = document.getElementById('deleteConfirmInput').value;
        if (confirm !== 'SUPPRIMER') {
            showMessage('Tapez SUPPRIMER', 'error');
            return;
        }
        if (!window._deleteId) return;
        try {
            await db.collection('poulailler_records').doc(window._deleteId).delete();
            document.getElementById('deleteModal').style.display = 'none';
            await loadProductions();
            showMessage('Production supprimée', 'success');
        } catch(error) {
            showMessage('Erreur', 'error');
        }
    });
    
    window.modifyProduction = function(id) {
        window._modifyId = id;
        const prod = allProductions.find(p => p.id === id);
        if (prod) {
            document.getElementById('modifyProductionName').value = prod.productionName || '';
            document.getElementById('modifyStartDate').value = prod.startDate ? new Date(prod.startDate).toISOString().split('T')[0] : '';
            document.getElementById('modifyEndDate').value = prod.endDate ? new Date(prod.endDate).toISOString().split('T')[0] : '';
            document.getElementById('modifyInitialStock').value = prod.initialStock || 0;
            document.getElementById('modifyModal').style.display = 'flex';
        }
    };
    
    window.deleteProduction = function(id) {
        window._deleteId = id;
        document.getElementById('deleteConfirmInput').value = '';
        document.getElementById('deleteModal').style.display = 'flex';
    };
    
    // Fermer modals au clic externe
    window.onclick = function(event) {
        if (event.target.classList.contains('modal')) {
            event.target.style.display = 'none';
        }
    };
    
    // Démarrer
    loadProductions();
</script>
</body>
</html> 
